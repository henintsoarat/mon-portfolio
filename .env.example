# true  → mode portfolio public (Vercel) — pas de portail ni d'auth
# false → mode portail complet avec login backend (Render)
VITE_PUBLIC_MODE=false

# URL du backend — à changer selon l'environnement
# Dev local : http://localhost:3001
# Render    : https://mon-portfolio-api.onrender.com
VITE_API_URL=http://localhost:3001
